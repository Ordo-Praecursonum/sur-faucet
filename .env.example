# Mnemonic of a FUNDED account the faucet sends from (required).
# For the local chain you can use a funded account from your chain config
# (e.g. alice). Keep this secret — never commit your real .env.
FAUCET_MNEMONIC="word word word ... (12 or 24 words)"

# Chain connection (defaults target a local `ignite chain serve`).
RPC_ENDPOINT="http://localhost:26657"
ADDRESS_PREFIX="sur"
DENOM="usur"
DISPLAY_DENOM="SUR"
EXPONENT="6"          # 1 SUR = 10^6 usur
GAS_PRICE="0.025usur"

# Faucet policy.
AMOUNT="10"           # SUR dispensed per base claim
COOLDOWN_HOURS="24"   # one claim per address per this many hours
SHARE_AMOUNT="20"     # bonus SUR for sharing a post that mentions the handle
SHARE_VIDEO_AMOUNT="100"  # bonus SUR instead of SHARE_AMOUNT when the post includes a video
SHARE_MAX_AGE_MINUTES="60"  # reject shares of posts older than this (0 disables); only enforced when the post's age is knowable
X_HANDLE="@SurProtocol"  # the handle a post must mention to earn the bonus

# Optional: X (Twitter) API v2 Bearer Token, used to verify share posts by
# reading the real tweet text. Falls back to the public oEmbed endpoint if
# unset or if the token's access tier can't read tweets.
X_BEARER_TOKEN=""

# Links / ports.
EXPLORER_URL="http://localhost:5173"   # Sur Scanner — used for the tx link
PORT="8787"
